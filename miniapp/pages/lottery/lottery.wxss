.page {
  padding: 20rpx;
}

.lottery-list {
  display: flex;
  flex-direction: column;
}

.lottery-item {
  margin-bottom: 20rpx;
}

.lottery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.lottery-period {
  display: flex;
  align-items: center;
}

.period-label {
  font-size: 28rpx;
  color: #666666;
}

.period-number {
  font-size: 36rpx;
  font-weight: 600;
  color: #e60012;
  margin: 0 8rpx;
}

.lottery-date {
  font-size: 26rpx;
  color: #999999;
}

.lottery-numbers {
  padding: 30rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.ball-separator {
  width: 2rpx;
  height: 48rpx;
  background-color: #e8e8e8;
  margin: 0 24rpx;
}

.lottery-prize {
  padding: 20rpx 30rpx;
  background-color: #fafafa;
  display: flex;
  flex-wrap: wrap;
}

.prize-item {
  width: 50%;
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.prize-label {
  font-size: 24rpx;
  color: #999999;
}

.prize-value {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
