.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-avatar.guest {
  background-color: rgba(255, 255, 255, 0.15);
}

.guest-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-name.guest text {
  font-size: 32rpx;
  opacity: 0.9;
}

.user-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.tag-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.6);
  border-right: 3rpx solid rgba(255, 255, 255, 0.6);
  transform: rotate(45deg);
}

/* 功能菜单 */
.menu-section {
  margin: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-item .arrow {
  border-color: #cccccc;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 20rpx;
}

.logout-btn {
  height: 88rpx;
  background-color: #ffffff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e8e8e8;
}

.logout-btn text {
  font-size: 30rpx;
  color: #999999;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.version {
  font-size: 24rpx;
  color: #cccccc;
  margin-bottom: 8rpx;
}

.copyright {
  font-size: 22rpx;
  color: #dddddd;
}
