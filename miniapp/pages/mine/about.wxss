.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.version {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  margin: 20rpx;
  padding: 30rpx;
}

.intro {
  margin-bottom: 40rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.features {
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  text-align: center;
}

.feature-text {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

.contact {
  padding-top: 20rpx;
}

.contact-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.contact-item {
  font-size: 26rpx;
  color: #666666;
  padding: 12rpx 0;
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx;
}

.copyright {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.disclaimer {
  font-size: 22rpx;
  color: #cccccc;
}
