<view class="page">
  <view class="header">
    <view class="logo">🎱</view>
    <view class="title">福彩助手</view>
    <view class="subtitle">便捷查询开奖信息</view>
  </view>

  <view class="content">
    <!-- 登录/注册切换 -->
    <view class="tabs">
      <view class="tab-item {{isLogin ? 'active' : ''}}" bindtap="switchMode">
        <text>登录</text>
      </view>
      <view class="tab-item {{!isLogin ? 'active' : ''}}" bindtap="switchMode">
        <text>注册</text>
      </view>
    </view>

    <!-- 表单 -->
    <view class="form">
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="请输入手机号" maxlength="11" 
          value="{{phone}}" bindinput="inputPhone"/>
      </view>

      <view class="form-item">
        <text class="form-label">验证码</text>
        <input class="form-input code-input" type="number" placeholder="请输入验证码" maxlength="6"
          value="{{code}}" bindinput="inputCode"/>
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="getCode">
          <text wx:if="{{countdown > 0}}">{{countdown}}s</text>
          <text wx:else>获取验证码</text>
        </view>
      </view>

      <!-- 协议同意 -->
      <view class="agreement" bindtap="toggleAgree">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <view class="agreement-text">
          <text>我已阅读并同意</text>
          <text class="link" catchtap="goToUserAgreement">《用户协议》</text>
          <text>和</text>
          <text class="link" catchtap="goToPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <!-- 登录/注册按钮 -->
      <view class="submit-btn" bindtap="{{isLogin ? 'login' : 'register'}}">
        <text class="btn-text">{{isLogin ? '登录' : '注册'}}</text>
      </view>
    </view>

    <!-- 微信登录 -->
    <view class="divider">
      <view class="line"></view>
      <text class="text">其他方式</text>
      <view class="line"></view>
    </view>

    <view class="other-login">
      <view class="wx-login" bindtap="wxLogin">
        <text class="wx-icon">💬</text>
        <text class="wx-text">微信一键登录</text>
      </view>
    </view>
  </view>
</view>
