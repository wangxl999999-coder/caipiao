.page {
  padding-bottom: 20rpx;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 340rpx;
  position: relative;
}

.banner swiper-item {
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-header {
  margin: 20rpx;
  margin-bottom: 0;
  padding: 24rpx 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.news-list {
  padding: 20rpx;
}

.news-item {
  margin-bottom: 20rpx;
}

.news-content {
  padding: 24rpx 30rpx;
}

.news-content.has-image {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.news-text {
  flex: 1;
  padding-right: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.news-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.news-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.news-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.news-time {
  margin-right: 20rpx;
}

.news-source {
  color: #666666;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
