.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f5 0%, #ffffff 100%);
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
}

.content {
  padding: 0 60rpx;
}

.tabs {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 48rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #666666;
}

.tab-item.active {
  background-color: #ffffff;
  color: #e60012;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(230, 0, 18, 0.1);
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 30rpx;
  position: relative;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-input.code-input {
  padding-right: 220rpx;
}

.code-btn {
  position: absolute;
  right: 12rpx;
  top: 54rpx;
  height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.code-btn.disabled {
  background: #cccccc;
}

.agreement {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  border-color: #e60012;
}

.checkbox.checked text {
  color: #ffffff;
  font-size: 22rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.link {
  color: #e60012;
}

.submit-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(230, 0, 18, 0.3);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.divider {
  display: flex;
  align-items: center;
  margin: 60rpx 0 40rpx;
}

.divider .line {
  flex: 1;
  height: 1rpx;
  background-color: #e8e8e8;
}

.divider .text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.other-login {
  display: flex;
  justify-content: center;
}

.wx-login {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  background-color: #07c160;
  border-radius: 44rpx;
}

.wx-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.wx-text {
  font-size: 28rpx;
  color: #ffffff;
}
