<view class="page">
  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots="{{indicatorDots}}" autoplay="{{autoplay}}" interval="{{interval}}" duration="{{duration}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ffffff" wx:if="{{banners.length > 0}}">
    <block wx:for="{{banners}}" wx:key="id">
      <swiper-item bindtap="goToBannerDetail" data-id="{{item.id}}">
        <image class="banner-image" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view class="banner-title">{{item.title}}</view>
      </swiper-item>
    </block>
  </swiper>

  <!-- 标签栏 -->
  <view class="section-header card">
    <view class="section-title">
      <view class="title-icon">📰</view>
      <text>新闻资讯</text>
    </view>
  </view>

  <!-- 新闻列表 -->
  <view class="news-list">
    <view class="news-item card" wx:for="{{newsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="news-content" wx:if="{{!item.cover_image}}">
        <view class="news-title">{{item.title}}</view>
        <view class="news-meta">
          <text class="news-time">{{item.formattedTime}}</text>
          <text class="news-source" wx:if="{{item.source}}">{{item.source}}</text>
        </view>
      </view>
      <view class="news-content has-image" wx:else>
        <view class="news-text">
          <view class="news-title">{{item.title}}</view>
          <view class="news-meta">
            <text class="news-time">{{item.formattedTime}}</text>
          </view>
        </view>
        <image class="news-cover" src="{{item.cover_image}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="no-more" wx:if="{{!hasMore && newsList.length > 0}}">
    <text>没有更多了</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && newsList.length === 0}}">
    <text class="empty-icon">📰</text>
    <text class="empty-text">暂无新闻资讯</text>
  </view>
</view>
