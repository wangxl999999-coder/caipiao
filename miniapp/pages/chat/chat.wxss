.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.message-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.messages {
  display: flex;
  flex-direction: column;
}

.message-item {
  margin-bottom: 24rpx;
}

.message-item.service {
  display: flex;
  flex-direction: column;
}

.message-item.user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-time {
  text-align: center;
  margin-bottom: 16rpx;
}

.message-time text {
  font-size: 22rpx;
  color: #cccccc;
  background-color: rgba(0, 0, 0, 0.05);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.message-content {
  display: flex;
  align-items: flex-start;
  max-width: 80%;
}

.message-item.service .message-content {
  flex-direction: row;
}

.message-item.user .message-content {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar.service {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  margin-right: 16rpx;
}

.avatar.user {
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  margin-left: 16rpx;
}

.avatar-icon {
  font-size: 40rpx;
}

.bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  word-break: break-all;
  position: relative;
}

.bubble.service {
  background-color: #ffffff;
  border-top-left-radius: 4rpx;
}

.bubble.user {
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
  border-top-right-radius: 4rpx;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.bubble.service .bubble-text {
  color: #333333;
}

.bubble.user .bubble-text {
  color: #ffffff;
}

.send-failed {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  padding-right: 96rpx;
}

.failed-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.failed-text {
  font-size: 22rpx;
  color: #ff4d4f;
}

/* 输入区域 */
.input-section {
  display: flex;
  align-items: flex-end;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
}

.input-wrapper {
  flex: 1;
  margin-right: 16rpx;
}

.message-input {
  width: 100%;
  min-height: 80rpx;
  max-height: 200rpx;
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e8e8e8;
  border-radius: 40rpx;
}

.send-btn.active {
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
}

.send-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
}

.send-btn.active text {
  color: #ffffff;
}
