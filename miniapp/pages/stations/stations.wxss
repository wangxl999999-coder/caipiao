.page {
  padding: 20rpx;
}

.location-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  background-color: #fff7e6;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #ffd591;
}

.tip-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #d48806;
  margin-bottom: 20rpx;
  text-align: center;
}

.tip-btn {
  padding: 16rpx 40rpx;
  background-color: #faad14;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.station-list {
  display: flex;
  flex-direction: column;
}

.station-item {
  margin-bottom: 20rpx;
}

.station-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.station-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.station-distance {
  margin-left: 20rpx;
}

.distance-text {
  font-size: 26rpx;
  color: #e60012;
  font-weight: 500;
  background-color: rgba(230, 0, 18, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.station-info {
  padding: 20rpx 30rpx;
}

.info-item {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: #999999;
  min-width: 140rpx;
}

.info-value {
  color: #333333;
  flex: 1;
}

.station-actions {
  display: flex;
  padding: 0 30rpx 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  margin-right: 20rpx;
}

.action-btn:last-child {
  margin-right: 0;
}

.action-primary {
  background: linear-gradient(135deg, #e60012 0%, #ff4d4f 100%);
}

.action-secondary {
  background-color: #f5f5f5;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-primary .action-icon,
.action-primary .action-text {
  color: #ffffff;
}

.action-secondary .action-icon,
.action-secondary .action-text {
  color: #666666;
}

.action-text {
  font-size: 26rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: #999999;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
